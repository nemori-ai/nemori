# === LLM Configuration (for chat completions) ===
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=                          # optional, e.g. https://openrouter.ai/api/v1

# === Embedding Configuration ===
EMBEDDING_API_KEY=your_embedding_api_key_here
EMBEDDING_BASE_URL=                    # optional, e.g. https://openrouter.ai/api/v1

# === Fallback (used when LLM_API_KEY / EMBEDDING_API_KEY are not set) ===
OPENAI_API_KEY=your_openai_api_key_here
