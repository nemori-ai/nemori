# === LLM Configuration ===
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://openrouter.ai/api/v1    # OpenRouter, or leave empty for direct OpenAI

# === Embedding Configuration ===
EMBEDDING_API_KEY=your_api_key_here           # Can be same as LLM_API_KEY for OpenRouter
EMBEDDING_BASE_URL=https://openrouter.ai/api/v1

# === Database ===
# Default connects to Docker Compose PostgreSQL
# DSN=postgresql://nemori:nemori@localhost:5432/nemori

# === Qdrant ===
# Default connects to Docker Compose Qdrant at localhost:6333
# QDRANT_URL=localhost
# QDRANT_PORT=6333
